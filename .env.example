# Copie este arquivo para .env e preencha os valores reais.
# NUNCA suba o .env para o GitHub — adicione ao .gitignore!

# Sua chave da API da Anthropic
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXX

# Porta local (serviços de hospedagem definem isso automaticamente)
PORT=3000

# Origens permitidas (separadas por vírgula).
# Coloque a URL do seu frontend após hospedar.
# Use * para liberar tudo (só em desenvolvimento).
ALLOWED_ORIGINS=https://seu-driftask.vercel.app,http://localhost:5500
